async function scrapeCnblogs() {
  let browser;
  
  try {
    // 启动浏览器
    browser = await chromium.launch({
      headless: true,
      args: ['--no-sandbox', '--disable-setuid-sandbox']
    });
    
    const context = await browser.newContext({
      userAgent: 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36'
    });
    
    const page = await context.newPage();
    
    // 访问博客园首页
    console.log('正在访问博客园首页...');
    await page.goto('https://www.cnblogs.com/', {
      waitUntil: 'domcontentloaded',
      timeout: 30000
    });
    
    // 等待页面加载
    await page.waitForTimeout(3000);
    
    // 尝试多个可能的选择器
    let articleLinks = [];
    const selectors = [
      '.post-item-title a',
      '.post_item_body h3 a',
      '.titlelnk',
      'article a[href*="cnblogs.com"]',
      '.post-list a[href*="/p/"]'
    ];
    
    console.log('尝试查找文章链接...');
    for (const selector of selectors) {
      try {
        const links = await page.$(selector);
        if (links.length > 0) {
          console.log(`使用选择器找到 ${links.length} 个链接: ${selector}`);
          articleLinks = await page.$eval(selector, links => 
            links
              .filter(link => link.href && link.href.includes('cnblogs.com'))
              .map(link => ({
                title: link.textContent.trim(),
                url: link.href
              }))
              .filter(item => item.title && item.url)
          );
          
          if (articleLinks.length > 0) {
            console.log(`成功获取 ${articleLinks.length} 篇文章`);
            break;
          }
        }
      } catch (e) {
        console.log(`选择器 ${selector} 失败:`, e.message);
        continue;
      }
    }
    
    if (articleLinks.length === 0) {
      // 如果还是找不到，输出页面内容用于调试
      const pageContent = await page.content();
      console.log('页面HTML片段:', pageContent.substring(0, 500));
      throw new Error('未找到文章链接，请检查博客园页面结构是否变化');
    }
    
    // 随机选择一篇文章
    const randomIndex = Math.floor(Math.random() * articleLinks.length);
    const selectedArticle = articleLinks[randomIndex];
    
    console.log(`随机选择文章: ${selectedArticle.title}`);
    console.log(`文章URL: ${selectedArticle.url}`);
    
    // 访问选中的文章
    await page.goto(selectedArticle.url, {
      waitUntil: 'networkidle',
      timeout: 30000
    });
    
    // 等待文章内容加载
    await page.waitForSelector('#cnblogs_post_body', { timeout: 10000 });
    
    // 获取文章详细信息
    const articleInfo = await page.evaluate(() => {
      const titleEl = document.querySelector('#cb_post_title_url, .postTitle a, h1');
      const authorEl = document.querySelector('#profile_block a, .postDesc a');
      const dateEl = document.querySelector('#post-date, .postDesc span');
      
      return {
        title: titleEl ? titleEl.textContent.trim() : '未知标题',
        author: authorEl ? authorEl.textContent.trim() : '未知作者',
        date: dateEl ? dateEl.textContent.trim() : '未知日期',
        url: window.location.href
      };
    });
    
    // 生成PDF文件名（使用时间戳避免重复）
    const timestamp = Date.now();
    const sanitizedTitle = articleInfo.title
      .replace(/[^a-zA-Z0-9\u4e00-\u9fa5]/g, '_')
      .substring(0, 50);
    const pdfFileName = `cnblogs_${sanitizedTitle}_${timestamp}.pdf`;
    const pdfPath = path.join('/tmp', pdfFileName);
    
    // 生成PDF
    console.log('正在生成PDF...');
    await page.pdf({
      path: pdfPath,
      format: 'A4',
      margin: {
        top: '20px',
        right: '20px',
        bottom: '20px',
        left: '20px'
      },
      printBackground: true
    });
    
    console.log(`PDF已生成: ${pdfPath}`);
    
    // 读取PDF文件为base64（用于在n8n中传递）
    const pdfBuffer = fs.readFileSync(pdfPath);
    const pdfBase64 = pdfBuffer.toString('base64');
    
    // 清理临时文件
    fs.unlinkSync(pdfPath);
    
    await browser.close();
    
    // 返回结果
    return {
      success: true,
      article: {
        title: articleInfo.title,
        author: articleInfo.author,
        date: articleInfo.date,
        url: articleInfo.url,
        pdfFileName: pdfFileName,
        pdfBase64: pdfBase64,
        pdfSize: pdfBuffer.length
      }
    };
    
  } catch (error) {
    if (browser) {
      await browser.close();
    }
    
    console.error('错误:', error.message);
    return {
      success: false,
      error: error.message,
      stack: error.stack
    };
  }
}

// n8n Code 节点执行
return await scrapeCnblogs();
